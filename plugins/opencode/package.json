{
  "name": "@kb/plugin-opencode",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "default": "./dist/index.js"
    },
    "./server": {
      "default": "./dist/index.js"
    },
    "./tui": {
      "default": "./dist/tui.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run clean && bun build ./src/index.ts --outfile ./dist/index.js --target bun && bun build ./src/tui.ts --outfile ./dist/tui.js --target bun",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "bun run --watch src/index.ts",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kb/core": "workspace:*"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.14.22"
  }
}
