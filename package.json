{
  "name": "kb-agent",
  "private": true,
  "packageManager": "bun@1.1.38",
  "workspaces": [
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:core": "bun run --filter @kb/core dev",
    "check": "turbo run check",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "turbo": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
